# ============================================
# 다담 SaaS 백엔드 환경변수 (FastAPI)
# ============================================
# 실제 .env 파일은 .gitignore 에 포함되어야 합니다.

# --------------------------------------------
# Supabase (필수)
# --------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --------------------------------------------
# AI
# --------------------------------------------
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
REPLICATE_API_TOKEN=
OPENAI_API_KEY=

# --------------------------------------------
# Stripe (해외/카드)
# --------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# --------------------------------------------
# 토스페이먼츠 (구독 빌링)
# --------------------------------------------
# 토스 빌링 백엔드는 Cloudflare Worker 로 이관 → workers/payments-api/wrangler.toml
# 시크릿(TOSS_SECRET_KEY 등) 은 `wrangler secret put` 또는 Cloudflare 대시보드에서 등록.
# 본 .env 에는 토스 관련 키를 더 이상 두지 않음.

# --------------------------------------------
# 인프라
# --------------------------------------------
REDIS_URL=redis://localhost:6379
SENTRY_DSN=

# --------------------------------------------
# 앱
# --------------------------------------------
ENVIRONMENT=development
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
