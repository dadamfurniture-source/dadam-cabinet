# ============================================
# 다담 SaaS 백엔드 환경변수 (FastAPI)
# ============================================
# 실제 .env 파일은 .gitignore 에 포함되어야 합니다.

# --------------------------------------------
# Supabase (필수)
# --------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --------------------------------------------
# AI
# --------------------------------------------
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
REPLICATE_API_TOKEN=
OPENAI_API_KEY=

# --------------------------------------------
# Stripe (해외/카드)
# --------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# --------------------------------------------
# 토스페이먼츠 (국내 구독 빌링)
# --------------------------------------------
# 테스트 키: test_sk_* / test_ck_*  실서비스 키: live_sk_* / live_ck_*
TOSS_CLIENT_KEY=test_ck_your_client_key
TOSS_SECRET_KEY=test_sk_your_secret_key
TOSS_WEBHOOK_SECRET=
# 플랜별 월 가격 (원, VAT 포함)
TOSS_PRICE_BASIC_KRW=99000
TOSS_PRICE_PRO_KRW=199000
TOSS_PRICE_ENTERPRISE_KRW=299000
# 기본 PG (미지정 시 사용)
DEFAULT_PAYMENT_PROVIDER=toss

# --------------------------------------------
# 인프라
# --------------------------------------------
REDIS_URL=redis://localhost:6379
SENTRY_DSN=

# --------------------------------------------
# 앱
# --------------------------------------------
ENVIRONMENT=development
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
